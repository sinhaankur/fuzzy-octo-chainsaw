# External market/news providers
ALPHAVANTAGE_API_KEY=
SERPAPI_KEY=

# Optional local Claude AI provider
ENABLE_LOCAL_CLAUDE=false
LOCAL_CLAUDE_BASE_URL=http://127.0.0.1:8080
LOCAL_CLAUDE_MODEL=claude-3-5-sonnet
LOCAL_CLAUDE_API_KEY=

# Optional auto-discovery of local LLM providers (default true)
# Detects in this order: Ollama, OpenAI-compatible local server, local Claude-compatible endpoint.
ENABLE_LOCAL_LLM_AUTO_DISCOVERY=true

# Optional local provider endpoints
OLLAMA_BASE_URL=http://127.0.0.1:11434
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:1234
LOCAL_OPENAI_API_KEY=

# Privacy controls
# Default is strict: uploaded symbols are not sent to external providers.
# Set to 'off' only if you explicitly want to enrich user symbols using external APIs.
STOCK_PRIVACY_MODE=strict

# External APIs will use these safe reference symbols when privacy mode is strict.
PUBLIC_REFERENCE_SYMBOLS=AAPL,MSFT,NVDA,SPY,GLD,TSLA
